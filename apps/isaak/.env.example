# ==============================================================================
# ISAAK — Variables de entorno (ejemplo)
# Copia este archivo a .env.local y rellena los valores reales.
# ==============================================================================

# ------------------------------------------------------------------------------
# Base de datos
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/db?sslmode=require
DIRECT_DATABASE_URL=postgresql://user:password@host:5432/db?sslmode=require

# ------------------------------------------------------------------------------
# Sesión y autenticación
# ------------------------------------------------------------------------------
SESSION_SECRET=your-session-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=your-nextauth-secret

# ------------------------------------------------------------------------------
# URLs públicas
# ------------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://isaak.verifactu.business

# ------------------------------------------------------------------------------
# IA — Proveedores (Anthropic + OpenAI con fallback automático)
#
# Isaak usa ambos proveedores. Claude es el primario por defecto.
# Si Claude falla (rate limit / red) el sistema reintenta con GPT automáticamente.
# El usuario NO necesita su propia cuenta en Anthropic ni OpenAI.
# ------------------------------------------------------------------------------

# Anthropic — Claude (primario por defecto)
ANTHROPIC_API_KEY=sk-ant-your-key
# Alias específico de Isaak (tiene prioridad sobre ANTHROPIC_API_KEY si está presente)
ISAAK_ANTHROPIC_API_KEY=

# OpenAI — GPT (fallback automático o primario si ISAAK_AI_PROVIDER_DEFAULT=openai)
ISAAK_NEW_OPENAI_API_KEY=sk-proj-your-key
# Alias genérico (fallback si ISAAK_NEW_OPENAI_API_KEY no está)
OPENAI_API_KEY=

# Proveedor por defecto: anthropic | openai | gateway
ISAAK_AI_PROVIDER_DEFAULT=anthropic

# Proveedor fallback automático (se detecta automáticamente si no se define:
# si primary=anthropic → fallback=openai y viceversa)
# ISAAK_AI_FALLBACK_PROVIDER=openai

# Modelos por defecto (opcional — el código tiene valores sensatos)
# ISAAK_AI_MODEL_DEFAULT=gpt-4.1-mini
# ISAAK_AI_MODEL_CLAUDE_DEFAULT=claude-haiku-4-5-20251001
# ISAAK_AI_FALLBACK_MODEL=gpt-4.1-mini

# Override de provider por feature específica:
# ISAAK_AI_PROVIDER_WORKSPACE_CHAT_FREE=anthropic
# ISAAK_AI_PROVIDER_PUBLIC_CHAT=anthropic
# ISAAK_AI_PROVIDER_HOLDED_CHAT=anthropic

# Vercel AI Gateway (alternativa — usar modelo en formato "provider/model")
# CLAVE_API_AI_VERCEL=your-vercel-ai-gateway-key

# ------------------------------------------------------------------------------
# Stripe — Facturación
# ------------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Price IDs en Stripe (crear en dashboard o CLI)
STRIPE_PRICE_STARTER_MONTHLY=price_...   # 19 €/mes
STRIPE_PRICE_STARTER_ANNUAL=price_...    # 15.20 €/mes = 182 €/año
STRIPE_PRICE_PRO_MONTHLY=price_...       # 49 €/mes
STRIPE_PRICE_PRO_ANNUAL=price_...        # 39.20 €/mes = 470 €/año
STRIPE_PRICE_BUSINESS_MONTHLY=price_...  # 149 €/mes
STRIPE_PRICE_BUSINESS_ANNUAL=price_...   # 119.20 €/mes = 1.430 €/año

# ------------------------------------------------------------------------------
# Google OAuth — Calendar + Gmail + Drive
# ------------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ------------------------------------------------------------------------------
# Push notifications (Web Push / PWA)
# Generar con: npx web-push generate-vapid-keys
# ------------------------------------------------------------------------------
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key  # igual que VAPID_PUBLIC_KEY
VAPID_SUBJECT=mailto:soporte@verifactu.business

# ------------------------------------------------------------------------------
# Email transaccional (Resend)
# ------------------------------------------------------------------------------
RESEND_API_KEY=re_your-resend-key
RESEND_FROM=Isaak <noreply@verifactu.business>

# ------------------------------------------------------------------------------
# Cron jobs (Vercel Cron lo inyecta automáticamente en producción)
# Para pruebas locales, genera un UUID: openssl rand -hex 32
# ------------------------------------------------------------------------------
CRON_SECRET=your-cron-secret

# ------------------------------------------------------------------------------
# Open Banking — Salt Edge
# ------------------------------------------------------------------------------
SALTEDGE_CLIENT_ID=your-saltedge-client-id
SALTEDGE_SERVICE_SECRET=your-saltedge-service-secret

# ------------------------------------------------------------------------------
# Open Banking — Enable Banking (AIS, PSD2)
# Application registered at https://enablebanking.com/cp/applications
# ------------------------------------------------------------------------------
# UUID of your Enable Banking application (shown in the control panel)
ENABLE_BANKING_APP_ID=your-enable-banking-app-id
# RSA 4096-bit private key (PKCS8 PEM), base64-encoded or as a raw PEM string.
# Generate: openssl genrsa -out eb_private.key 4096
#           openssl req -new -x509 -days 730 -key eb_private.key -out eb_public.crt
# Then upload eb_public.crt to the control panel and set this var.
ENABLE_BANKING_PRIVATE_KEY=your-base64-encoded-pem-private-key

# ------------------------------------------------------------------------------
# Firebase (autenticación)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n

# ------------------------------------------------------------------------------
# Seguridad — CSRF, cookies, write tokens (audit 2026-05)
# ------------------------------------------------------------------------------
# Default cookie SameSite=lax (mitiga CSRF). Solo cambiar a 'none' si tienes
# iframes/embeds cross-site reales (verifica los dominios listados a abajo
# también; sin Domain compartido, 'none' implica también Secure=true).
# SESSION_COOKIE_SAMESITE=lax

# Hosts adicionales permitidos por el middleware Origin-check (CSRF C3).
# Default whitelist incluye: isaak.app, isaak.verifactu.business,
# app.verifactu.business, verifactu.business, localhost, 127.0.0.1.
# Coma-separada. Solo añadir hosts cuya UI hace POST/PATCH/DELETE legítimos
# al backend de isaak.
# ISAAK_ALLOWED_ORIGINS=mi-dominio.com,otro-host.example

# HMAC secret para firmar tokens de "permitir escrituras" en chat (SEC C5).
# Si no se setea, cae a SESSION_SECRET (compat) y se loguea console.warn.
# Para enforcement estricto, además poner ISAAK_WRITES_REQUIRE_TOKEN=true.
# Genera con: openssl rand -hex 32
# WRITE_TOKEN_SECRET=

# Si true, el chat SOLO ejecuta tools de escritura cuando el cliente adjunta
# un writeToken válido (UI toggle). Si false (default), comportamiento legacy
# decidido por el LLM classifier + console.warn de auditoría.
# ISAAK_WRITES_REQUIRE_TOKEN=false

# ------------------------------------------------------------------------------
# AEAT — corpus + worker submission
# ------------------------------------------------------------------------------
# Activa la ingesta de PDFs (manuales AEAT). Sin esto, solo se indexan
# fuentes HTML (BOE consolidados, INFORMA, sede FAQs).
# CORPUS_PDF_EXTRACTOR_ENABLED=1

# C-B1.c — worker headless Playwright que envía .303/.130/.111 a AEAT.
# Default false: el cron /api/cron/aeat-submission-worker hace no-op y
# las submissions quedan en pending_aeat hasta que un worker externo
# (con Playwright instalado) las procese. Solo poner true cuando el
# worker esté deployado en Cloud Run / Fly / GitHub Actions.
# AEAT_SUBMISSION_WORKER_ENABLED=false

# Entorno AEAT para el browser adapter: 'pre' (sandbox) o 'prod'.
# AEAT_ENVIRONMENT=pre

# Cuántas submissions procesa el worker por corrida.
# AEAT_WORKER_BATCH_SIZE=5

# ==============================================================================
# CROSS-APP URLS (links al landing público y al hub de conectores Holded)
# ==============================================================================
NEXT_PUBLIC_HOLDED_SITE_URL=https://holded.verifactu.business
