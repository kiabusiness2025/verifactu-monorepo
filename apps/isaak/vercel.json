{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd ../.. && npx -y pnpm@10.27.0 install --no-frozen-lockfile",
  "buildCommand": "cd ../.. && npx -y pnpm@10.27.0 --filter @verifactu/db run db:migrate:deploy && npx -y pnpm@10.27.0 turbo run build --filter=verifactu-isaak",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/trial-expiry",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/fiscal-alerts",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/connector-health",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/eb-sync",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/banking-alerts",
      "schedule": "30 7 * * *"
    },
    {
      "path": "/api/cron/onboarding-nudge",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/audit-monthly",
      "schedule": "0 3 1 * *"
    },
    {
      "path": "/api/cron/aeat-sede-sync",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/aeat-weekly-summary",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/aeat-corpus-reingest",
      "schedule": "0 4 1 1,4,7,10 *"
    },
    {
      "path": "/api/cron/app-health",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/webhook-retry",
      "schedule": "*/5 * * * *"
    }
  ]
}
