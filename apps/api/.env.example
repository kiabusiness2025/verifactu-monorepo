# ========================================================================
# VERIFACTU API - ENVIRONMENT CONFIGURATION (EXAMPLE)
# ========================================================================

# --- Session ---
SESSION_SECRET=replace-with-session-secret

# --- Admin access (CSV lists) ---
ADMIN_UIDS=uid1,uid2
ADMIN_EMAILS=admin@example.com,soporte@verifactu.business

# --- AEAT / VeriFactu secrets ---
# Certificado de colaborador social o representante legal (.p12)
# En local: ruta absoluta al archivo en apps/api/certs/ (excluido de git)
# En producción (Render): montar como secret file en /var/secrets/aeat_cert/cert.p12
AEAT_CERT_PATH=/var/secrets/aeat_cert/cert.p12

# Archivo de texto con la contraseña del certificado .p12 (una sola línea)
# En local: apps/api/certs/aeat_cert_pass.txt
# En producción (Render): montar como secret file en /var/secrets/aeat_pass/cert_pass.txt
AEAT_CERT_PASS_PATH=/var/secrets/aeat_pass/cert_pass.txt

# Archivo de texto con la ruta al WSDL de la AEAT (una sola línea)
# La AEAT exige mTLS para descargar el WSDL vía HTTPS, por eso se usa un archivo local.
#
# PASO 1: Descargar el WSDL de la AEAT:
#   Buscar "VeriFactu WSDL" en https://www.agenciatributaria.es/AEAT.internet/en_gb/Inicio/La_Agencia_Tributaria/Campanas/Verifactu/
#   o solicitar el archivo a la AEAT. Guardar como apps/api/certs/SistemaFacturacion.wsdl
# PASO 2: El archivo .txt debe contener la ruta relativa al .wsdl:
#   Contenido: certs/SistemaFacturacion.wsdl
# En producción (Render): montar el WSDL como secret file en /var/secrets/aeat_wsdl/SistemaFacturacion.wsdl
#   y el .txt debe contener: /var/secrets/aeat_wsdl/SistemaFacturacion.wsdl
AEAT_WSDL_FILE=/var/secrets/aeat_wsdl/wsdl_url.txt

# --- Database (if API needs DB access) ---
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require
POSTGRES_URL=postgres://user:password@host:5432/dbname?sslmode=require
PRISMA_DATABASE_URL=prisma+postgres://accelerate.prisma-data.net/?api_key=replace-with-api-key

# --- Runtime ---
PORT=8080
NODE_ENV=production
