{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "50mb",
        "includeFiles": ["public/**"]
      }
    }
  ],
  "routes": [{ "src": "/(.*)", "dest": "/src/index.ts" }]
}
