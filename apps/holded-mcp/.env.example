# ============================================================
# Holded MCP Server — claude.verifactu.business
# Copia este fichero a .env y rellena los valores reales
# ============================================================

# Servidor
PORT=3000
NODE_ENV=production
BASE_URL=https://claude.verifactu.business
CORS_ALLOWED_ORIGINS=https://claude.ai,https://app.claude.ai
DATABASE_URL=postgresql://postgres:password@localhost:5432/verifactu?schema=public

# OAuth 2.0
# Genera un secreto seguro: openssl rand -hex 32
OAUTH_JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRETO_SEGURO_DE_64_CHARS
OAUTH_DATA_ENCRYPTION_SECRET=CAMBIA_ESTO_POR_OTRO_SECRETO_SEGURO_DE_64_CHARS
OAUTH_AUTH_CODE_TTL_SECONDS=600
OAUTH_TOKEN_TTL_SECONDS=3600
OAUTH_REFRESH_TOKEN_TTL_SECONDS=2592000

# OAuth Client para Claude (Anthropic lo asigna al publicar en el directorio)
# Para desarrollo puedes usar cualquier valor
OAUTH_CLIENT_ID=claude-holded-connector
OAUTH_CLIENT_SECRET=CAMBIA_ESTO_POR_OTRO_SECRETO

# Holded API
HOLDED_API_BASE=https://api.holded.com

# Bridge Firebase auth → consent screen (T#50)
# OBLIGATORIO para que /oauth/authorize redirija a holded-direct en lugar
# de mostrar el form legacy con email plano. Mismo valor que SESSION_SECRET
# en apps/holded (Vercel) y apps/app (Vercel). Sin esto el conector Claude
# muestra la pantalla de conexión antigua sin Google ni magic link.
SESSION_SECRET=MISMO_VALOR_QUE_EN_APPS_HOLDED_Y_APPS_APP

# URL del Next.js de Holded (donde vive /auth/holded-direct y /auth/holded-claude)
# Por defecto https://holded.verifactu.business — solo cambiar si hay otro dominio
# HOLDED_PUBLIC_URL=https://holded.verifactu.business

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
