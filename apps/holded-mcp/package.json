{
  "name": "holded-mcp-server",
  "version": "1.0.0",
  "description": "Official Holded MCP connector for Claude",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "sync:brand": "node scripts/sync-brand-assets.mjs",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src/**/*.ts",
    "test": "node --import tsx --test test/tools.test.ts test/auth-and-metadata.test.ts test/oauth.test.ts test/holded-client.test.ts test/create-invoice-draft.test.ts test/branding.test.ts test/redirects.test.ts",
    "validate-branding": "node scripts/validate-branding.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.1",
    "helmet": "^7.1.0",
    "jose": "^5.2.0",
    "node-fetch": "^3.3.2",
    "pg": "^8.16.3",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.15.5",
    "tsx": "^4.6.0",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": "20.x"
  }
}
