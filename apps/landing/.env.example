# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Holded-specific Firebase project (optional)
# If defined, /auth/holded will use these values instead of NEXT_PUBLIC_FIREBASE_*
NEXT_PUBLIC_HOLDED_FIREBASE_API_KEY=
NEXT_PUBLIC_HOLDED_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_HOLDED_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_HOLDED_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_HOLDED_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_HOLDED_FIREBASE_APP_ID=

# Firebase Emulator (optional, for local development)
NEXT_PUBLIC_USE_AUTH_EMULATOR=false

# Google AI API Key (para Genkit con Gemini - gratis hasta 15 req/min)
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# OpenAI API Key (para GPT-4 en sistema híbrido)
OPENAI_API_KEY=your_openai_api_key_here

# Legacy OpenAI Assistant (mantener por compatibilidad con código anterior)
ISAAK_ASSISTANT_ID=your_assistant_id_here

# Sesión cross-subdominio (app.verifactu.business)
NEXT_PUBLIC_APP_URL=https://app.verifactu.business
SESSION_SECRET=generated_shared_secret_from_node_crypto
SESSION_SECRET_PREVIOUS=

# Session Cookie Configuration (Optional)
# Cookie domain (e.g., ".verifactu.business" for cross-subdomain cookies)
# Default: auto-detected based on host
# For local: SESSION_COOKIE_DOMAIN=localhost
SESSION_COOKIE_DOMAIN=

# Cookie secure flag (true/false)
# Default: auto-detected from URL protocol
SESSION_COOKIE_SECURE=

# Cookie sameSite (lax/strict/none)
# Default: lax
SESSION_COOKIE_SAMESITE=lax

# Firebase Admin (para firmar cookie __session)
# Obtener de: Firebase Console → Project Settings → Service Accounts
# → Generate new private key
# IMPORTANTE: El mismo SESSION_SECRET debe estar en apps/app/.env.local
FIREBASE_ADMIN_PROJECT_ID=your_project_id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nTU_PRIVATE_KEY_AQUI\n-----END PRIVATE KEY-----\n"

# Database (PostgreSQL - required for tenant/user management)
DATABASE_URL=postgresql://user:password@localhost:5432/verifactu?sslmode=disable

# Vercel KV (optional, enables distributed rate limiting across instances)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Stripe (for payments)
STRIPE_SECRET_KEY=sk_test_xxx_or_sk_live_xxx
