# =============================================================================
# HOLDED PUBLIC APP CONFIGURATION (Example)
# =============================================================================
NEXT_PUBLIC_HOLDED_SITE_URL=https://holded.verifactu.business
HOLDED_PUBLIC_URL=https://holded.verifactu.business
NEXT_PUBLIC_HOLDED_ENABLE_GOOGLE_LOGIN=true
SESSION_SECRET=your-session-secret
SESSION_COOKIE_DOMAIN=.localhost
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=none

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL=your-database-url
DIRECT_DATABASE_URL=your-direct-database-url

# =============================================================================
# SHARED INTEGRATIONS / HOLDed
# =============================================================================
INTEGRATIONS_SECRET_KEY=your-32-byte-secret
HOLDED_API_BASE_URL=https://api.holded.com
HOLDED_TIMEOUT_MS=10000
HOLDED_TEST_API_KEY=your-holded-test-api-key
HOLDED_ADMIN_NOTIFICATION_EMAILS=soporte@verifactu.business
HOLDED_ADMIN_EMAILS=soporte@verifactu.business
HOLDED_LEAD_EMAIL=soporte@verifactu.business

# =============================================================================
# FIREBASE WEB APP FOR holded.verifactu.business
# =============================================================================
# IMPORTANT: Para que el magic link de correo funcione, el dominio
# holded.verifactu.business debe estar en la lista de Authorized Domains
# en Firebase Console → Authentication → Settings → Authorized domains.
# =============================================================================
NEXT_PUBLIC_HOLDED_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_HOLDED_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_HOLDED_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_HOLDED_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_HOLDED_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_HOLDED_FIREBASE_APP_ID=your-firebase-app-id
NEXT_PUBLIC_HOLDED_RECAPTCHA_SITE_KEY=your-recaptcha-v3-site-key
NEXT_PUBLIC_HOLDED_FIREBASE_APP_CHECK_DEBUG_TOKEN=
FIREBASE_ADMIN_PROJECT_ID=your-firebase-admin-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=your-firebase-admin-client-email
FIREBASE_ADMIN_PRIVATE_KEY=your-firebase-admin-private-key

# =============================================================================
# EMAIL / NOTIFICATIONS
# =============================================================================
RESEND_API_KEY=your-resend-api-key
RESEND_FROM=your-default-resend-from
RESEND_FROM_HOLDED=your-holded-resend-from
RESEND_REPLY_TO=soporte@verifactu.business

# =============================================================================
# OPTIONAL SHARED ADMIN ACCESS
# =============================================================================
ADMIN_EMAILS=soporte@verifactu.business,kiabuasiness2025@gmail.com
