# Holded Vercel Import - TEMPLATE (NO SECRETS)
# Proyecto destino: apps/holded
# IMPORTANTE: SESSION_SECRET debe ser el mismo que usa app.verifactu.business

NODE_ENV=production

# URL publica de la app principal (onboarding + chat)
NEXT_PUBLIC_APP_URL=https://app.verifactu.business

# URL publica del nuevo proyecto Holded (cancelaciones y enlaces internos)
HOLDED_PUBLIC_URL=https://holded.verifactu.business

# Cookie/session compartida para reconocer usuario autenticado
SESSION_SECRET=replace-with-shared-session-secret

# Firebase web app (OAuth en /auth/holded)
NEXT_PUBLIC_FIREBASE_API_KEY=replace-with-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=replace-with-firebase-auth-domain
NEXT_PUBLIC_FIREBASE_PROJECT_ID=replace-with-firebase-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=replace-with-firebase-storage-bucket
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=replace-with-firebase-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=replace-with-firebase-app-id

# Recomendado: importar tambien las variables especificas de Holded.
# Asi evitas ambiguedad si el flujo de acceso se sirve desde Landing o desde Holded.
NEXT_PUBLIC_HOLDED_FIREBASE_API_KEY=replace-with-firebase-api-key
NEXT_PUBLIC_HOLDED_FIREBASE_AUTH_DOMAIN=replace-with-firebase-auth-domain
NEXT_PUBLIC_HOLDED_FIREBASE_PROJECT_ID=replace-with-firebase-project-id
NEXT_PUBLIC_HOLDED_FIREBASE_STORAGE_BUCKET=replace-with-firebase-storage-bucket
NEXT_PUBLIC_HOLDED_FIREBASE_MESSAGING_SENDER_ID=replace-with-firebase-messaging-sender-id
NEXT_PUBLIC_HOLDED_FIREBASE_APP_ID=replace-with-firebase-app-id

# Firebase Admin (validación de idToken en /api/auth/session)
FIREBASE_ADMIN_PROJECT_ID=replace-with-firebase-admin-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=replace-with-firebase-admin-client-email
FIREBASE_ADMIN_PRIVATE_KEY=replace-with-firebase-admin-private-key

# Stripe
STRIPE_SECRET_KEY=replace-with-stripe-secret-key
STRIPE_PRICE_HOLDED_FISCAL_MONTHLY=price_replace_fiscal_monthly
STRIPE_PRICE_HOLDED_FISCAL_YEARLY=price_replace_fiscal_yearly
STRIPE_PRICE_HOLDED_MIGRACIONES_MONTHLY=price_replace_migraciones_monthly
STRIPE_PRICE_HOLDED_MIGRACIONES_YEARLY=price_replace_migraciones_yearly
