# Holded Vercel Import - TEMPLATE (NO SECRETS)
# Proyecto destino: apps/holded
# IMPORTANTE: SESSION_SECRET debe ser el mismo que usa app.verifactu.business

NODE_ENV=production

# URL publica de la app principal (onboarding + chat)
NEXT_PUBLIC_APP_URL=https://app.verifactu.business

# URL publica del nuevo proyecto Holded (cancelaciones y enlaces internos)
HOLDED_PUBLIC_URL=https://holded.verifactu.business

# Cookie/session compartida para reconocer usuario autenticado
SESSION_SECRET=replace-with-shared-session-secret

# Stripe
STRIPE_SECRET_KEY=replace-with-stripe-secret-key
STRIPE_PRICE_HOLDED_FISCAL_MONTHLY=price_replace_fiscal_monthly
STRIPE_PRICE_HOLDED_FISCAL_YEARLY=price_replace_fiscal_yearly
STRIPE_PRICE_HOLDED_MIGRACIONES_MONTHLY=price_replace_migraciones_monthly
STRIPE_PRICE_HOLDED_MIGRACIONES_YEARLY=price_replace_migraciones_yearly
