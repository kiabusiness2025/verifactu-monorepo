{
  "name": "@verifactu/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for the Isaak Platform API (Verifactu Business)",
  "license": "MIT",
  "homepage": "https://verifactu.business/developers",
  "repository": {
    "type": "git",
    "url": "https://github.com/kiabusiness2025/verifactu-monorepo",
    "directory": "packages/sdk"
  },
  "keywords": [
    "verifactu",
    "aeat",
    "facturacion",
    "spain",
    "fiscal",
    "sdk"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
