model ExternalConnection {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  provider          String
  channelKey        String    @default("dashboard") @map("channel_key")
  providerAccountId String?   @map("provider_account_id")
  credentialType    String    @default("api_key") @map("credential_type")
  apiKeyEnc         String?   @map("api_key_enc")
  scopesGranted     String[]  @default([]) @map("scopes_granted")
  connectionStatus  String    @default("disconnected") @map("connection_status")
  connectedByUserId String?   @map("connected_by_user_id")
  connectedAt       DateTime? @map("connected_at") @db.Timestamptz
  lastValidatedAt   DateTime? @map("last_validated_at") @db.Timestamptz
  lastSyncAt        DateTime? @map("last_sync_at") @db.Timestamptz
  legalTermsAcceptedAt DateTime? @map("legal_terms_accepted_at") @db.Timestamptz
  legalPrivacyAcceptedAt DateTime? @map("legal_privacy_accepted_at") @db.Timestamptz
  legalAcceptanceVersion String? @map("legal_acceptance_version")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connectedByUser User?     @relation("ExternalConnectionConnectedByUser", fields: [connectedByUserId], references: [id], onDelete: SetNull)
  auditLogs       ExternalConnectionAuditLog[]
  syncRuns        ExternalSyncRun[]

  @@unique([tenantId, provider, channelKey])
  @@index([tenantId, provider, channelKey, connectionStatus])
  @@index([connectedByUserId])
  @@map("external_connections")
}

model ChannelIdentity {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
