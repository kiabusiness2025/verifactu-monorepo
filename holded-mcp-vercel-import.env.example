# ============================================================
# Holded MCP (conector Claude) — Vercel Import TEMPLATE (NO SECRETS)
# Proyecto destino: apps/holded-mcp
# ============================================================
# Copia este fichero a `.env`, rellena los valores reales y usa
# "Import .env" en Vercel (Project Settings -> Environment Variables).
#
# Fuente de verdad del esquema: apps/holded-mcp/src/config.ts
# El servidor hace process.exit(1) si falta cualquier variable obligatoria.
#
# ⚠️ CRITICO — si este proyecto comparte la MISMA base de datos que el
# despliegue actual (Railway) y/o que apps/app, estos secretos DEBEN ser
# IDENTICOS a los que ya estan en uso, NO regenerarlos:
#   - OAUTH_JWT_SECRET            (valida tokens OAuth ya emitidos)
#   - OAUTH_DATA_ENCRYPTION_SECRET (descifra API keys de Holded ya guardadas)
#   - SESSION_SECRET             (compartido con apps/holded y apps/app)
#   - VERIFACTU_APP_SHARED_SECRET (compartido con apps/app)
# Copialos tal cual desde el proyecto Railway / apps/app. Regenerarlos
# rompe los tokens y las conexiones existentes.
# ============================================================

# --- Servidor ---
NODE_ENV=production
# PORT no se usa en Vercel (serverless, sin listen) — se ignora sin problema.
PORT=3000

# --- URL publica ---
# ⚠️ DEBE coincidir EXACTAMENTE con el dominio donde se sirve este deploy.
# Es el `issuer` OAuth (RFC 8414): si no coincide, Claude rechaza el conector.
#   - Staging / preview:  https://<tu-proyecto>.vercel.app
#   - Produccion (gated): https://claude.verifactu.business
BASE_URL=https://REEMPLAZA-CON-LA-URL-DEL-DEPLOY

# Origenes permitidos para CORS (clientes Claude)
CORS_ALLOWED_ORIGINS=https://claude.ai,https://app.claude.ai
# Allowlist de redirect_uri OAuth (opcional; vacio = sin restriccion extra)
# OAUTH_ALLOWED_REDIRECT_ORIGINS=https://claude.ai

# --- Base de datos (OAuth store) ---
# OBLIGATORIO en produccion. Debe ser el MISMO Postgres que usa apps/app.
DATABASE_URL=replace-with-postgres-connection-string
# Solo para rollout degradado de emergencia. Dejar en 0.
ALLOW_STATELESS_OAUTH_IN_PRODUCTION=0

# --- OAuth 2.0 ---
# Genera secretos nuevos solo si es un entorno aislado: openssl rand -hex 32
# Si comparte BD con Railway/apps/app -> COPIA los valores existentes.
OAUTH_JWT_SECRET=replace-with-oauth-jwt-secret-min-32-chars
OAUTH_DATA_ENCRYPTION_SECRET=replace-with-data-encryption-secret-min-32-chars
OAUTH_AUTH_CODE_TTL_SECONDS=600
OAUTH_TOKEN_TTL_SECONDS=3600
OAUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
OAUTH_CLIENT_ID=replace-with-oauth-client-id
OAUTH_CLIENT_SECRET=replace-with-oauth-client-secret-min-16-chars

# --- Holded API ---
HOLDED_API_BASE=https://api.holded.com

# --- Bridge auth con el ecosistema Verifactu ---
# OBLIGATORIO en produccion. Mismo valor que SESSION_SECRET en apps/holded y apps/app.
SESSION_SECRET=replace-with-shared-session-secret-min-16-chars
VERIFACTU_APP_URL=https://app.verifactu.business
# OBLIGATORIO en produccion. Mismo valor que VERIFACTU_APP_SHARED_SECRET en apps/app.
VERIFACTU_APP_SHARED_SECRET=replace-with-verifactu-app-shared-secret
# URL del Next.js de Holded (auth/holded-direct + auth/holded-claude). Default OK.
HOLDED_PUBLIC_URL=https://holded.verifactu.business

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# --- Logging ---
LOG_LEVEL=info
