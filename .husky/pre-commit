#!/bin/sh
# Pre-commit hook - blocks commits with TypeScript or staged-file check errors.

set -e

STAGED_FILES=$(git diff --cached --name-only)

if [ -z "$STAGED_FILES" ]; then
  echo "No staged files to check"
  exit 0
fi

echo "Running lint-staged on staged files..."
pnpm exec lint-staged

echo "Running app TypeScript check..."
pnpm run typecheck:app

echo "Running landing TypeScript check..."
pnpm run typecheck:landing

echo "Running Holded TypeScript check..."
pnpm run typecheck:holded

echo "Pre-commit checks passed"
