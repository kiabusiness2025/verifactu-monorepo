# =============================================================================
# ISAAK AI MULTI-PROVIDER (packages/utils/ai)
# =============================================================================
# --- Provider & model defaults ---
# Which provider to use by default: openai | anthropic | gateway
ISAAK_AI_PROVIDER_DEFAULT=openai
# Default model for OpenAI (used when provider=openai and no model specified)
ISAAK_AI_MODEL_DEFAULT=gpt-4.1-mini
# Default model for Claude (used when provider=anthropic and no model specified)
ISAAK_AI_MODEL_CLAUDE_DEFAULT=claude-sonnet-4-5

# --- API keys ---
# OpenAI key for Isaak (Responses API + tool-heavy chat runtime)
ISAAK_NEW_OPENAI_API_KEY=your-openai-api-key
# Anthropic key for direct Claude access (adapter: anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-5
# Vercel AI Gateway key (adapter: gateway — routes openai/*, anthropic/*, etc.)
CLAVE_API_AI_VERCEL=your-vercel-ai-gateway-key

# --- Per-feature provider overrides (optional) ---
# Override the provider for a specific feature without changing the global default.
# Pattern: ISAAK_AI_PROVIDER_<FEATURE>=openai|anthropic|gateway
# Examples:
# ISAAK_AI_PROVIDER_HOLDED_CHAT=anthropic
# ISAAK_AI_PROVIDER_EMAIL=openai
# ISAAK_AI_PROVIDER_ADMIN=gateway
# ISAAK_AI_PROVIDER_LANDING_CHAT=anthropic

# =============================================================================
# VERCEL CONFIGURATION
# =============================================================================
VERCEL_OIDC_TOKEN=your-vercel-oidc-token

# =============================================================================
# SESSION CONFIGURATION (Development)
# =============================================================================
SESSION_SECRET=your-session-secret
SESSION_COOKIE_DOMAIN=.localhost
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=none
SUPPORT_HANDOFF_SECRET=your-support-handoff-secret

# =============================================================================
# APP URL CONFIGURATION
# =============================================================================
NEXT_PUBLIC_APP_URL=http://verifactu.business
VERIFACTU_API_URL=https://api.verifactu.business

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL=your-database-url
PRISMA_DATABASE_URL=your-prisma-database-url
POSTGRES_URL=your-postgres-url

# =============================================================================
# FIREBASE CLIENT CONFIGURATION (Public - Safe to expose to browser)
# =============================================================================
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-firebase-auth-domain
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-firebase-storage-bucket
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-firebase-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-v3-site-key
NEXT_PUBLIC_FIREBASE_APP_CHECK_DEBUG_TOKEN=your-firebase-app-check-debug-token
NEXT_PUBLIC_USE_AUTH_EMULATOR=false

# =============================================================================
# FIREBASE ADMIN CONFIGURATION (Private - Server-side only)
# =============================================================================
FIREBASE_ADMIN_PROJECT_ID=your-firebase-admin-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=your-firebase-admin-client-email
FIREBASE_ADMIN_PRIVATE_KEY=your-firebase-admin-private-key

# =============================================================================
# EINFORMA CONFIGURATION (Private - API de consulta de empresas)
# =============================================================================
EINFORMA_TOKEN_URL=https://api.einforma.com/oauth/token
EINFORMA_API_BASE_URL=https://developers.einforma.com/api/v1
EINFORMA_CLIENT_ID=your-einforma-client-id
EINFORMA_CLIENT_SECRET=your-einforma-client-secret
EINFORMA_SCOPE=buscar:consultar:empresas
EINFORMA_SEARCH_PARAMS=denominacion,nombre,cif,nif,q
EINFORMA_TIMEOUT_MS=8000

# Google OAuth (Gmail + Google Drive)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Microsoft OAuth (Outlook + OneDrive)
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# Genkit / Google AI (Gemini)
GOOGLE_AI_API_KEY=your-google-ai-api-key

EINFORMA_API_KEY=your-einforma-api-key
